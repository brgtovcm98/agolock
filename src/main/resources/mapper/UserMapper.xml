<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.seu.seustock.mapper.UserMapper">

    <resultMap id="UserResultMap" type="UserDTO">
        <id     property="id"         column="id"/>
        <result property="externalId" column="external_id"/>
        <result property="email"      column="email"/>
        <result property="nickname"   column="nickname"/>
        <result property="password"   column="password"/>
        <result property="createdAt"  column="created_at"/>
    </resultMap>

    <insert id="insertUser" parameterType="UserDTO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (email, nickname, password)
        VALUES (#{email}, #{nickname}, #{password})
    </insert>

    <select id="findByEmail" parameterType="string" resultMap="UserResultMap">
        SELECT id, external_id, email, nickname, password, created_at
        FROM users
        WHERE email = #{email}
    </select>

    <update id="updatePassword" parameterType="UserDTO">
        UPDATE users
        SET password = #{password}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM users
        WHERE id = #{id}
    </delete>

</mapper>
